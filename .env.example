# GitHub OAuth App (portal login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub account users must sponsor
GITHUB_SPONSOR_LOGIN=zortos293

# Maintainer PAT with read:sponsors (or admin:org for org sponsors) for periodic sync
GITHUB_TOKEN=

# Portal
PORTAL_SESSION_SECRET=change-me-to-a-long-random-string
PORTAL_PUBLIC_URL=https://proxy.opennow.example.com
PORTAL_PORT=3000

# Forward proxy (OpenNOW session proxy URL host/port)
PROXY_PORT=3128
PROXY_PUBLIC_HOST=proxy.opennow.example.com

# Shared data volume paths (inside containers)
DATABASE_PATH=/data/opennow-proxy.json
PROXY_PASSWD_PATH=/data/3proxy.passwd

# Sponsor credential sync interval in hours
SYNC_INTERVAL_HOURS=12

# Caddy / TLS (only when NOT using cloudflared)
CADDY_DOMAIN=proxy.opennow.example.com
CADDY_EMAIL=you@example.com

# Cloudflare Tunnel (see docs/DEPLOY-CLOUDFLARED.md)
CLOUDFLARE_TUNNEL_TOKEN=
