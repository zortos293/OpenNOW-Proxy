# Admin panel login (separate from proxy users)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session signing secret for admin cookie
PORTAL_SESSION_SECRET=change-me-to-a-long-random-string

# Public portal URL (optional, used for secure cookies behind HTTPS)
PORTAL_PUBLIC_URL=https://opennow-proxy.example.com
PORTAL_PORT=3000

# Forward proxy (OpenNOW session proxy URL host/port)
PROXY_PORT=3128
PROXY_PUBLIC_HOST=opennow-proxy-tcp.example.com

# Shared data volume paths (inside containers)
DATABASE_PATH=/data/opennow-proxy.json
PROXY_PASSWD_PATH=/data/3proxy.passwd

# Caddy / TLS (only when NOT using cloudflared)
CADDY_DOMAIN=opennow-proxy.example.com
CADDY_EMAIL=you@example.com

# Cloudflare Tunnel (see docs/DEPLOY-CLOUDFLARED.md)
CLOUDFLARE_TUNNEL_TOKEN=
