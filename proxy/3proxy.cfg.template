# OpenNOW session proxy — NVIDIA/GFN domains only (deny-by-default)
pidfile /var/run/3proxy.pid
nscache 65536
nserver 1.1.1.1
nserver 8.8.8.8

log /dev/stdout D
logformat "L%t.%. %N.%p %E %U %C:%c %R:%r %O %I %h %T"

users ${PROXY_PASSWD_PATH}
auth strong
allow * * games.geforce.com
allow * * *.nvidiagrid.net
deny * *

proxy -p${PROXY_PORT} -a
